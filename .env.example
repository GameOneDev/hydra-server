HYDRA_SERVER_BIND=0.0.0.0:8788
# URL your friends' launchers can reach this server on (reverse proxy domain)
HYDRA_SERVER_PUBLIC_URL=http://localhost:8788
HYDRA_SERVER_DATA_DIR=./data
# Official API used to validate launcher access tokens
HYDRA_OFFICIAL_API_URL=https://hydra-api-us-east-1.losbroxas.org
# Required to enable the /admin panel
HYDRA_ADMIN_PASSWORD=
# 0 = unlimited; e.g. 10737418240 = 10 GiB per user
HYDRA_MAX_BYTES_PER_USER=0
HYDRA_BACKUPS_PER_GAME_LIMIT=100
# Comma-separated official user ids or usernames; empty = anyone with a Hydra login
HYDRA_ALLOWED_USERS=
# Check GitHub for newer server releases and flag them in the admin panel.
# Set to 0/false to disable (e.g. air-gapped installs)
HYDRA_UPDATE_CHECK=true
# Hours between update checks (minimum 1)
HYDRA_UPDATE_CHECK_INTERVAL_HOURS=6
# owner/repo whose GitHub releases are compared against the running version
HYDRA_UPDATE_REPO=gameonedev/hydra-server
# Default for auto-install: when true, detected updates download and install
# themselves (and the server restarts). Off by default — you just get notified.
# Also toggleable live from the admin panel. No effect inside a container.
HYDRA_AUTO_UPDATE=false
